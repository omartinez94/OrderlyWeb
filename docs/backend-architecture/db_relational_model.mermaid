erDiagram
    Users ||--o{ Orders : creates
    Users ||--o{ Reservations : creates
    Users ||--o{ OrderModificationLog : modifies
    Users ||--o{ BulkOrderUploads : uploads
    Users ||--o{ Baskets : creates
    
    Customers ||--o{ Orders : places

    Restaurants ||--o{ Users : employs
    Restaurants ||--o{ Tables : contains
    Restaurants ||--o{ MenuCategories : has
    Restaurants ||--o{ MenuItems : offers
    Restaurants ||--o{ Ingredients : stocks
    Restaurants ||--o{ Orders : processes
    Restaurants ||--o{ Reservations : accepts
    Restaurants ||--o{ WalkInQueue : manages
    Restaurants ||--o{ PriceHistory : tracks
    Restaurants ||--o{ Baskets : "active in"
    Restaurants ||--o{ Coupons : "issues"
    
    Tables ||--o{ Orders : "assigned to"
    Tables ||--o{ Reservations : "reserved for"
    Tables ||--o{ MergedTables : "parent of"
    Tables ||--o{ MergedTables : "child of"
    Tables ||--o{ WalkInQueue : "seated at"
    Tables ||--o{ Baskets : "assigned to"
    
    MenuCategories ||--o{ MenuSubCategories : contains
    MenuSubCategories ||--o{ MenuItems : includes
    
    MenuItems ||--o{ OrderItems : "ordered as"
    MenuItems ||--o{ MenuItemVariations : "has variations"
    MenuItems ||--o{ ComboItems : "combo parent"
    MenuItems ||--o{ ComboItems : "included in combo"
    MenuItems ||--o{ MenuItemIngredients : requires
    MenuItems ||--o{ MenuItemAnalytics : tracked
    MenuItems ||--o{ PriceHistory : "price changes"
    MenuItems ||--o{ BasketItems : "in basket"
    
    Ingredients ||--o{ MenuItemIngredients : "used in"
    Ingredients ||--o{ IngredientAlternatives : "original ingredient"
    Ingredients ||--o{ IngredientAlternatives : "alternative for"
    
    Orders ||--o{ OrderItems : contains
    Orders ||--o{ OrderBills : "split into"
    Orders ||--o{ OrderModificationLog : "tracked by"
    Orders ||--o{ CustomerFeedback : "receives feedback"
    Orders ||--o{ NotificationLog : triggers
    Orders ||--o{ OrderTimingAnalytics : analyzed
    Orders ||--o{ OrderSnapshot : "price snapshot"
    
    Baskets ||--o{ BasketItems : contains
    Baskets ||--o{ Users : "belongs to"
    
    OrderItems ||--o{ OrderItemPriceAudit : "audit trail"
    
    Reservations ||--o{ NotificationLog : triggers
    
    CustomerFeedback ||--o{ Orders : "redeems reward in"
    
    Customers {
        uuid Id PK
        string Email
        string Name
        string Phone
        string CreatedBy
        timestamp CreatedAt
        string LastModifiedBy
        timestamp LastModifiedAt
        boolean IsActive
    }

    Users {
        uuid Id PK
        string Email UK
        string PasswordHash
        string FirstName
        string LastName
        string PhoneNumber
        enum Role "Admin,Manager,Waiter,KitchenStaff"
        uuid RestaurantId FK
        boolean IsActive
        timestamp CreatedAt
        timestamp UpdatedAt
    }
    
    Restaurants {
        uuid Id PK
        uuid BrandId
        string Name
        text Address
        string PhoneNumber
        string Email
        decimal TaxRate "Current tax rate"
        string Currency
        string TimeZone
        boolean AutoConfirmOrders
        boolean AutoConfirmReservations
        boolean AllowAutoSubstitute
        int EstimatedTurnoverMinutes
        string CreatedBy
        timestamp CreatedAt
        string LastModifiedBy
        timestamp LastModifiedAt
        boolean IsActive
    }
    
    Tables {
        uuid Id PK
        uuid RestaurantId FK
        string TableNumber UK
        int Capacity
        int PositionX
        int PositionY
        string Shape
        enum Status "available,occupied,reserved,cleaning,needs_attention"
        uuid CurrentOrderId FK
        boolean IsActive
        timestamp CreatedAt
        timestamp UpdatedAt
    }
    
    MergedTables {
        uuid Id PK
        uuid ParentTableId FK
        uuid ChildTableId FK
        timestamp MergedAt
        timestamp SplitAt
        boolean IsActive
    }
    
    MenuCategories {
        int Id PK
        uuid RestaurantId FK
        string Name
        text Description
        int DisplayOrder
        boolean IsActive
        boolean IsDeleted "Soft delete"
        timestamp CreatedAt
        timestamp DeletedAt
    }
    
    MenuSubCategories {
        int Id PK
        int CategoryId FK
        string Name
        text Description
        int DisplayOrder
        boolean IsActive
        boolean IsDeleted "Soft delete"
        timestamp DeletedAt
    }
    
    MenuItems {
        uuid Id PK
        uuid RestaurantId FK
        int SubCategoryId FK
        string Name
        text Description
        decimal BasePrice "Current base price"
        string ImageUrl "Mandatory"
        int PrepTimeMinutes
        int PrepTimeMaxMinutes
        enum ItemType "regular,combo,promo,seasonal"
        boolean IsAvailable
        enum AvailabilityStatus "available,limited,unavailable"
        date SeasonStartDate
        date SeasonEndDate
        decimal PromoPrice
        timestamp PromoStartDate
        timestamp PromoEndDate
        int DisplayOrder
        boolean IsActive
        boolean IsDeleted "Soft delete for historical data"
        timestamp CreatedAt
        timestamp UpdatedAt
        timestamp DeletedAt
    }
    
    MenuItemVariations {
        int Id PK
        uuid MenuItemId FK
        string Name "e.g. Size, Spice"
        string VariationValue "e.g. Large, Extra Spicy"
        decimal PriceModifier "Current price modifier"
        boolean IsDefault
        int DisplayOrder
        boolean IsDeleted "Soft delete"
        timestamp DeletedAt
    }
    
    ComboItems {
        int Id PK
        uuid ComboMenuItemId FK
        uuid IncludedMenuItemId FK
        int Quantity
        boolean IsOptional
    }
    
    Ingredients {
        int Id PK
        uuid RestaurantId FK
        string Name UK
        string Unit "kg,liters,units"
        decimal CurrentStock
        decimal MinimumStock
        boolean IsAvailable
        timestamp LastUpdated
    }
    
    MenuItemIngredients {
        int Id PK
        uuid MenuItemId FK
        int IngredientId FK
        decimal QuantityRequired
        boolean IsOptional
    }
    
    IngredientAlternatives {
        int Id PK
        int OriginalIngredientId FK
        int AlternativeIngredientId FK
        decimal PriceModifier "Current price modifier"
        boolean AutoSubstitute
        uuid RestaurantId FK
    }
    
    PriceHistory {
        int Id PK
        uuid RestaurantId FK
        uuid MenuItemId FK "NULL for ingredient alternatives"
        int IngredientAlternativeId FK "NULL for menu items"
        int VariationId FK "NULL for base prices"
        enum PriceType "base_price,variation,ingredient_alternative"
        decimal OldPrice
        decimal NewPrice
        string Reason "Price increase, promotion, etc"
        uuid ChangedByUserId FK
        timestamp EffectiveDate
        timestamp CreatedAt
    }
    
    Orders {
        uuid Id PK
        uuid RestaurantId FK
        string OrderNumber UK "R1-20231015-001"
        enum OrderType "dine-in,takeout,delivery"
        uuid TableId FK
        uuid CustomerId FK
        text DeliveryAddress
        decimal DeliveryLatitude
        decimal DeliveryLongitude
        text DeliveryNotes
        enum DeliveryStatus "pending,dispatched,delivered"
        enum Status "ordering,pending,confirmed,preparing,ready,delivered,completed,cancelled,on_hold"
        decimal Subtotal "SNAPSHOT at order time"
        decimal TaxAmount "SNAPSHOT calculated"
        decimal TaxRate "SNAPSHOT of restaurant tax rate"
        decimal TotalAmount "SNAPSHOT final total"
        decimal DiscountAmount
        string DiscountCode "Applied promo/reward code"
        string Currency "SNAPSHOT of restaurant currency"
        boolean IsModified
        boolean RequiresAdminApproval
        uuid ApprovedByAdminId FK
        timestamp ApprovedAt
        int EstimatedPrepTimeMinutes
        int ActualPrepTimeMinutes
        uuid CreatedByUserId FK
        uuid ConfirmedByUserId FK
        uuid CompletedByUserId FK
        text Notes
        string CreatedBy
        timestamp CreatedAt
        string LastModifiedBy
        timestamp LastModifiedAt
        boolean IsActive
        timestamp ConfirmedAt
        timestamp PreparingStartedAt
        timestamp ReadyAt
        timestamp DeliveredAt
        timestamp CompletedAt
        timestamp CancelledAt
    }
    
    OrderItems {
        int Id PK
        uuid OrderId FK
        uuid MenuItemId FK "NULL if item deleted"
        string MenuItemName "SNAPSHOT name"
        text MenuItemDescription "SNAPSHOT description"
        string MenuItemImageUrl "SNAPSHOT image"
        int Quantity
        decimal BasePrice "SNAPSHOT base price"
        decimal UnitPrice "SNAPSHOT final unit price"
        decimal TotalPrice "SNAPSHOT total for this item"
        jsonb SelectedVariations "SNAPSHOT with prices"
        jsonb Customizations "SNAPSHOT with prices"
        int SeatNumber "For bill splitting"
        enum PrepStatus "pending,preparing,ready"
        timestamp PrepStartedAt
        timestamp PrepCompletedAt
        text SpecialInstructions
        timestamp CreatedAt
    }
    
    OrderSnapshot {
        int Id PK
        uuid OrderId FK
        jsonb FullOrderData "Complete order snapshot JSON"
        jsonb MenuPricesSnapshot "All menu prices at order time"
        jsonb TaxConfiguration "Tax rules at order time"
        jsonb DiscountRules "Discount configuration snapshot"
        text GeneratedReceiptHtml "Pre-generated receipt"
        string SnapshotHash "SHA256 for integrity"
        timestamp CreatedAt
    }
    
    OrderItemPriceAudit {
        int Id PK
        int OrderItemId FK
        uuid MenuItemId
        decimal MenuBasePrice "From menu at order time"
        decimal AppliedBasePrice "Actually charged"
        jsonb VariationsBreakdown "Each variation with price"
        decimal VariationsPriceTotal
        jsonb CustomizationsBreakdown "Each customization with price"
        decimal CustomizationsPriceTotal
        decimal FinalUnitPrice
        decimal DiscountApplied
        string DiscountSource "promo_code, reward, manual"
        uuid CapturedByUserId FK
        timestamp CapturedAt
    }
    
    OrderModificationLog {
        int Id PK
        uuid OrderId FK
        uuid ModifiedByUserId FK
        string PreviousStatus
        string NewStatus
        string ModificationType "status_change,item_added,item_removed,price_change,manager_override"
        jsonb PreviousData "Complete state before change"
        jsonb NewData "Complete state after change"
        jsonb PriceImpact "Price differences"
        boolean RequiresApproval
        uuid ApprovedByUserId FK
        timestamp ApprovedAt
        timestamp CreatedAt
    }
    
    OrderBills {
        int Id PK
        uuid OrderId FK
        int BillNumber UK "1,2,3"
        enum SplitType "equal,custom"
        decimal Amount "SNAPSHOT subtotal"
        decimal TaxAmount "SNAPSHOT tax"
        decimal TotalAmount "SNAPSHOT total"
        enum PaymentStatus "pending,paid,void"
        string PaymentMethod "cash,card,transfer"
        text PaymentReference
        timestamp PaidAt
        text Notes
        timestamp CreatedAt
    }
    
    Reservations {
        uuid Id PK
        uuid RestaurantId FK
        string ReservationNumber UK
        string CustomerName
        string CustomerPhone
        string CustomerEmail
        int PartySize
        date ReservationDate
        time ReservationTime
        uuid TableId FK
        enum Status "pending,confirmed,seated,completed,cancelled,no_show"
        boolean RequiresApproval
        uuid ApprovedByUserId FK
        timestamp ApprovedAt
        text SpecialRequests
        text Notes
        boolean ReminderSent
        timestamp ReminderSentAt
        uuid CreatedByUserId FK
        timestamp CreatedAt
        timestamp ConfirmedAt
        timestamp SeatedAt
        timestamp CompletedAt
        timestamp CancelledAt
    }
    
    WalkInQueue {
        int Id PK
        uuid RestaurantId FK
        string CustomerName
        string CustomerPhone
        int PartySize
        enum Status "waiting,notified,seated,cancelled,no_show"
        int EstimatedWaitMinutes
        timestamp NotifiedAt
        timestamp SeatedAt
        uuid TableId FK
        timestamp CreatedAt
        timestamp UpdatedAt
    }
    
    CustomerFeedback {
        int Id PK
        uuid OrderId FK
        uuid RestaurantId FK
        int FoodQualityRating "1-5"
        int ServiceSpeedRating "1-5"
        int WaiterFriendlinessRating "1-5"
        int OverallRating "1-5"
        text Comments
        string RewardCode UK
        string RewardType "percentage,free_item,points"
        decimal RewardValue
        text RewardDescription
        boolean RewardRedeemed
        timestamp RedeemedAt
        uuid RedeemedInOrderId FK
        timestamp SubmittedAt
    }
    
    OrderTimingAnalytics {
        int Id PK
        uuid OrderId FK
        uuid RestaurantId FK
        int OrderingToPendingSeconds
        int PendingToConfirmedSeconds
        int ConfirmedToPreparingSeconds
        int PreparingToReadySeconds
        int ReadyToDeliveredSeconds
        int TotalTimeSeconds
        int EstimatedPrepMinutes
        int ActualPrepMinutes
        int PrepTimeDifferenceMinutes
        uuid WaiterUserId FK
        int KitchenStaffCount
        timestamp RecordedAt
    }
    
    MenuItemAnalytics {
        int Id PK
        uuid MenuItemId FK
        uuid RestaurantId FK
        date AnalysisDate UK
        int TimesOrdered
        decimal TotalRevenue
        decimal AvgPrepTimeMinutes
        int TimesModified
        int TimesOutOfStock
        int MorningOrders "6AM-12PM"
        int AfternoonOrders "12PM-6PM"
        int EveningOrders "6PM-12AM"
        int NightOrders "12AM-6AM"
    }
    
    NotificationLog {
        int Id PK
        enum RecipientType "customer,staff,manager"
        string RecipientIdentifier "phone/email"
        enum Channel "email,whatsapp,sms"
        string MessageType "order_confirmation,feedback_request"
        uuid RelatedOrderId FK
        uuid RelatedReservationId FK
        text MessageContent
        enum Status "pending,sent,failed"
        timestamp SentAt
        text FailureReason
        timestamp CreatedAt
    }
    
    BulkOrderUploads {
        int Id PK
        uuid RestaurantId FK
        uuid UploadedByUserId FK
        string FileName
        int TotalRows
        int SuccessfulRows
        int FailedRows
        enum Status "pending,processing,completed,failed"
        jsonb ErrorLog
        uuid ApprovedByAdminId FK
        timestamp ApprovedAt
        timestamp CreatedAt
        timestamp CompletedAt
    }
    
    Baskets {
        uuid UserId PK
        uuid RestaurantId FK
        jsonb AppliedDiscounts
        decimal Subtotal "Calculated from items"
        timestamp CreatedAt
        timestamp ExpiresAt "Auto-expire after 2 hours"
    }
    
    BasketItems {
        uuid Id PK
        uuid BasketId FK
        int MenuItemId FK
        string MenuItemName "SNAPSHOT name"
        string MenuItemImageUrl "SNAPSHOT image"
        int Quantity
        decimal BasePrice "SNAPSHOT base price"
        decimal UnitPrice "SNAPSHOT final unit price"
        decimal TotalPrice "SNAPSHOT total"
        jsonb Variations "SNAPSHOT with prices"
        jsonb Customizations "SNAPSHOT with prices"
        text SpecialInstructions
        timestamp CreatedAt
    }
    
    Coupons {
        int Id PK
        uuid RestaurantId FK
        string Code UK
        string Description
        decimal Amount
        int MaxRedeemAmount
        timestamp ExpirationDate
        boolean IsActive
        string CreatedBy
        timestamp CreatedAt
        string LastModifiedBy
        timestamp LastModifiedAt
    }
